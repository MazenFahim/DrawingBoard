<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mazenfahim.drawingboard.DrawingController" stylesheets="@css/main.css">

    <StackPane fx:id="mainStackPane">
        <ScrollPane fx:id="canvasContainer" VBox.vgrow="ALWAYS" hbarPolicy="NEVER" vbarPolicy="NEVER">
            <Canvas fx:id="canvas" height="3000" width="3000"/>
        </ScrollPane>
        <ToolBar maxWidth="300" fx:id="toolBar">
            <ColorPicker fx:id="colorPicker"/>
            <Slider fx:id="brushSize" min="1" max="6" value="3" showTickLabels="true"
                    showTickMarks="true"
                    majorTickUnit="1"/>
            <Button fx:id="clear" id="clear" text="Clear"/>
        </ToolBar>
    </StackPane>

</VBox>
