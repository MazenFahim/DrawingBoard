<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import java.lang.String?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!-- Root StackPane lets the top bar float as an overlay -->
<StackPane fx:id="rootPane"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.mazenfahim.drawingboard.DrawingController"
           stylesheets="@main.css"
           onMouseMoved="#handleRootMouseMove"
           onMouseExited="#handleRootMouseExit">

    <!-- ─── Main content layer ─── -->
    <VBox fx:id="rootBox">

        <!-- ─── Canvas area ─── -->
        <StackPane fx:id="mainStackPane" VBox.vgrow="ALWAYS" styleClass="canvas-area">
            <Canvas fx:id="canvas"/>
        </StackPane>

        <!-- ─── Bottom toolbar ─── -->
        <HBox fx:id="toolBar" styleClass="toolbar-strip" alignment="CENTER_LEFT" spacing="8">
            <padding>
                <Insets top="8" right="16" bottom="8" left="16"/>
            </padding>

            <!-- ── Color group ── -->
            <HBox styleClass="tool-group" spacing="6" alignment="CENTER">
                <Label text="COLOR" styleClass="tool-label"/>
                <ColorPicker fx:id="colorPicker" styleClass="color-tool">
                    <tooltip><Tooltip text="Pick brush color"/></tooltip>
                </ColorPicker>
            </HBox>

            <!-- ── Brush group ── -->
            <HBox styleClass="tool-group" spacing="6" alignment="CENTER">
                <Label text="BRUSH" styleClass="tool-label"/>
                <Slider fx:id="brushSize" min="1" max="6" value="3" prefWidth="110"
                        styleClass="brush-slider">
                    <tooltip><Tooltip text="Brush size"/></tooltip>
                </Slider>
            </HBox>

            <!-- ── Tools group ── -->
            <HBox styleClass="tool-group" spacing="6" alignment="CENTER">
                <Button fx:id="clear" onAction="#clearCanvas" contentDisplay="GRAPHIC_ONLY" styleClass="tool-btn">
                    <graphic>
                        <FontIcon iconLiteral="mdi2e-eraser-variant" iconSize="15" iconColor="#475569"/>
                    </graphic>
                    <tooltip><Tooltip text="Clear canvas (C)"/></tooltip>
                </Button>
                <Button fx:id="eraser" onAction="#toggleEraser" contentDisplay="GRAPHIC_ONLY" styleClass="tool-btn">
                    <graphic>
                        <FontIcon fx:id="eraserIcon" iconLiteral="mdi2e-eraser" iconSize="15" iconColor="#475569"/>
                    </graphic>
                    <tooltip><Tooltip text="Toggle eraser (E)"/></tooltip>
                </Button>
            </HBox>

            <!-- ── Eraser size group ── -->
            <HBox styleClass="tool-group" spacing="6" alignment="CENTER">
                <Label text="ERASER" styleClass="tool-label"/>
                <Slider fx:id="eraserSize" min="5" max="40" value="10" prefWidth="90"
                        styleClass="brush-slider">
                    <tooltip><Tooltip text="Eraser size"/></tooltip>
                </Slider>
            </HBox>

            <Separator orientation="VERTICAL" styleClass="tool-sep"/>

            <!-- ── Theme toggle ── -->
            <Button fx:id="toggleBg" onAction="#toggleBackground" contentDisplay="GRAPHIC_ONLY">
                <graphic>
                    <FontIcon fx:id="themeIcon" iconLiteral="mdi2w-weather-night" iconSize="15" iconColor="#475569"/>
                </graphic>
                <tooltip><Tooltip text="Toggle dark/light canvas"/></tooltip>
                <styleClass>
                    <String fx:value="tool-btn"/>
                </styleClass>
            </Button>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- ── Slide navigation group ── -->
            <HBox styleClass="tool-group" spacing="6" alignment="CENTER">
                <Button onAction="#previousSlide" contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <FontIcon iconLiteral="mdi2c-chevron-left" iconSize="16" iconColor="#475569"/>
                    </graphic>
                    <tooltip><Tooltip text="Previous slide (←)"/></tooltip>
                    <styleClass>
                        <String fx:value="tool-btn"/>
                        <String fx:value="nav-btn"/>
                    </styleClass>
                </Button>

                <Label fx:id="currentSlide" text="1" styleClass="slide-badge"/>

                <Button onAction="#nextSlide" contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <FontIcon iconLiteral="mdi2c-chevron-right" iconSize="16" iconColor="#475569"/>
                    </graphic>
                    <tooltip><Tooltip text="Next slide (→)"/></tooltip>
                    <styleClass>
                        <String fx:value="tool-btn"/>
                        <String fx:value="nav-btn"/>
                    </styleClass>
                </Button>
            </HBox>

            <Button fx:id="addSlideBtn" text="+ New Slide" onAction="#addSlide">
                <tooltip><Tooltip text="Add new slide"/></tooltip>
                <styleClass>
                    <String fx:value="tool-btn"/>
                    <String fx:value="primary-btn"/>
                </styleClass>
            </Button>

            <Button fx:id="delete" text="Delete" onAction="#deleteSlide">
                <tooltip><Tooltip text="Delete current slide"/></tooltip>
                <styleClass>
                    <String fx:value="tool-btn"/>
                    <String fx:value="danger-btn"/>
                </styleClass>
            </Button>
        </HBox>
    </VBox>

    <!-- ─── Floating top bar overlay (doesn't affect layout below) ─── -->
    <VBox pickOnBounds="false">
        <HBox fx:id="topBar" styleClass="window-bar" alignment="CENTER_LEFT" spacing="14">
            <padding>
                <Insets top="10" right="16" bottom="10" left="16"/>
            </padding>

            <ImageView fitWidth="34" fitHeight="34" pickOnBounds="true" preserveRatio="true">
                <Image url="@icons/EasyBrush1.png"/>
            </ImageView>

            <VBox>
                <Label text="EasyBrush" styleClass="app-title"/>
                <Label text="Creative drawing workspace" styleClass="app-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="✦  Draw freely on the canvas" styleClass="window-hint"/>

            <HBox alignment="CENTER_RIGHT" spacing="6">
                <Button onAction="#minimizeWindow" contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <FontIcon iconLiteral="mdi2m-minus" iconSize="14" iconColor="white"/>
                    </graphic>
                    <tooltip><Tooltip text="Minimize"/></tooltip>
                    <styleClass>
                        <String fx:value="window-action-btn"/>
                    </styleClass>
                </Button>

                <Button fx:id="maximizeButton" onAction="#toggleMaximizeWindow" contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <FontIcon iconLiteral="mdi2w-window-maximize" iconSize="14" iconColor="white"/>
                    </graphic>
                    <tooltip><Tooltip text="Maximize"/></tooltip>
                    <styleClass>
                        <String fx:value="window-action-btn"/>
                    </styleClass>
                </Button>

                <Button onAction="#closeWindow" contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <FontIcon iconLiteral="mdi2c-close" iconSize="14" iconColor="white"/>
                    </graphic>
                    <tooltip><Tooltip text="Close"/></tooltip>
                    <styleClass>
                        <String fx:value="window-action-btn"/>
                        <String fx:value="window-close-btn"/>
                    </styleClass>
                </Button>
            </HBox>
        </HBox>
    </VBox>
</StackPane>
